# Environment Configuration Template

# BACKEND
FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True
SECRET_KEY=your-secret-key-here
API_PORT=5000
API_HOST=0.0.0.0

# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/count_me_in
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=count_me_in

# REDIS (for caching and real-time updates)
REDIS_URL=redis://localhost:6379/0

# YOLO MODEL
MODEL_TYPE=yolov8n  # Options: yolov8n, yolov8s, yolov8m, yolov10n, etc.
MODEL_PATH=models/yolo_v8/best.pt
CONFIDENCE_THRESHOLD=0.5
IOU_THRESHOLD=0.45

# EDGE INFERENCE
EDGE_DEVICE=cpu  # Options: cpu, cuda, tpu
EDGE_INFERENCE_TIMEOUT=5
BATCH_SIZE=1

# CAMERA SETTINGS
CAMERA_SOURCE=0  # Webcam index or RTSP URL
VIDEO_FPS=30
VIDEO_WIDTH=640
VIDEO_HEIGHT=480
SKIP_FRAMES=2

# OCCUPANCY SETTINGS
MAX_CAPACITY_THRESHOLD=85  # Alert when exceeds %
CRITICAL_CAPACITY_THRESHOLD=95  # Critical alert when exceeds %
OCCUPANCY_UPDATE_INTERVAL=5  # seconds

# ALERTS
ENABLE_ALERTS=True
ALERT_WEBHOOK_URL=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# DASHBOARD
DASHBOARD_PORT=3000
DASHBOARD_HOST=0.0.0.0
REACT_APP_API_URL=http://localhost:5000/api

# MOBILE APP
MOBILE_API_URL=https://api.yourdomain.com

# LOGGING
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# DOCKER
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_PREFIX=your-username
